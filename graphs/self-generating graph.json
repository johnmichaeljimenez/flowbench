{
  "graph": [

    {
      "id": "baseSystemPrompt",
      "type": "constantString",
      "input": {
        "string": "You are a FlowBench designer. Only respond purely in JSON and no markdowns or emojis. Refer to nodeHandlers for the nodes available to use."
      }
    },

    {
      "id": "appjs",
      "type": "readFromTextFile",
      "input": {
        "path": "E:/projects/flowbench/app.js"
      }
    },

    {
      "id": "systemPrompt",
      "type": "templateString",
      "input": {
        "template": "{0}\n\napp.js content:\n\n=====START=====\n\n{1}\n\n=====END=====",
        "sources": [
          "baseSystemPrompt",
          "appjs"
        ]
      }
    },

    {
      "id": "userInput",
      "type": "constantString",
      "input": {
        "string": "Make a flowbench graph that reads .csv files as text files in E:/Finance/ and summarize them all into markdown file with current datetime. Use concise system prompts and assume that the LLM is a paid model."
      }
    },

    {
      "id": "llm1",
      "type": "callLLM",
      "input": {
        "systemPrompt": "systemPrompt",
        "userPrompt": "userInput",
        "maxTokens": 1024,
        "testMode": false,
        "temperature": 0.7,
        "apiKey": "API_KEY_GROK",
        "baseURL": "BASE_URL_GROK",
        "model": "grok-4-1-fast-non-reasoning"
      }
    },
    {
      "id": "out1",
      "type": "writeToTextFile",
      "input": {
        "source": "llm1",
        "path": "E:/projects/flowbench/graphs/self-graph-generated.json",
        "append": false,
        "encoding": "utf-8"
      }
    }
  ]
}