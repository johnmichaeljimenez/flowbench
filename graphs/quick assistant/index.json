{
	"graph": [
		{
			"id": "sysPrompt",
			"type": "constantString",
			"input": {
				"string": "The date and time is: {{:datenow}}. You are a helpful assistant for quick, short-form questions and answers. If you are not sure about the answer, say 'I don't know', or provide alternative answers with confidence percentage how relevant it is. When asked to draw an image, charts, or graphs, use pure SVG code, enclose it directly as <svg>, without any Markdown code block."
			}
		},
		{
			"id": "userInput",
			"type": "constantString",
			"input": {
				"string": ""
			}
		},
		{
			"id": "llmChatGemini",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$sysPrompt",
				"userPrompt": "$userInput",
				"maxTokens": 4096,
				"temperature": 0.3,
				"apiKey": "API_KEY_GEMINI",
				"baseURL": "BASE_URL_GEMINI",
				"model": "gemini-3.1-flash-lite-preview"
			}
		},
		{
			"id": "llmChatGrok",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$sysPrompt",
				"userPrompt": "$userInput",
				"maxTokens": 4096,
				"temperature": 0.3,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning",
				"useTools": true
			}
		},
		{
			"id": "llmOutput",
			"type": "choose",
			"input": {
				"condition": false,
				"trueSource": "$llmChatGrok",
				"falseSource": "$llmChatGemini"
			}
		},
		{
			"id": "out1",
			"type": "outputLog",
			"input": {
				"source": "$llmOutput"
			}
		}
	],
	"form": [
		{
			"id": "userInput.string",
			"name": "Enter inquiry",
			"value": null,
			"type": "textarea",
			"required": true,
			"autoclear": true
		},
		{
			"type": "dropdown",
			"id": "llmOutput.condition",
			"name": "Model Type",
			"storeLast": true,
			"data": [
				{
					"value": "true",
					"display": "Grok 4.1 Reasoning + tools"
				},
				{
					"value": "false",
					"display": "Gemini 3.1 Flash"
				}
			],
			"defaultValue": "true",
			"required": true,
			"advanced": true
		}
	],
	"output": {
		"cards": [
			{
				"id": "out1.value",
				"type": "text",
				"name": "Response",
				"format": "markdown"
			},
			{
				"id": "userInput.value",
				"type": "text",
				"name": "User"
			}
		]
	},
	"meta": {
		"name": "Quick Assistant",
		"description": "Google Gemini 3.1 Flash (lite-preview) and Grok 4.1 (reasoning + tools) with image and chart drawing via SVG (experimental).",
		"disableConfirm": true,
		"notifyOnEnd": true
	}
}