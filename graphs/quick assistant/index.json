{
	"graph": [
		{
			"id": "sysPrompt",
			"type": "constantString",
			"input": {
				"string": "The date and time is: {{:datenow}}. You are a helpful assistant for quick, short-form questions and answers. If you are not sure about the answer, say 'I don't know', or provide alternative answers with confidence percentage how relevant it is. When asked to draw an image, use pure SVG code."
			}
		},
		{
			"id": "userInput",
			"type": "constantString",
			"input": {
				"string": ""
			}
		},
		{
			"id": "llmChat",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$sysPrompt",
				"userPrompt": "$userInput",
				"maxTokens": 1024,
				"temperature": 0.3,
				"apiKey": "API_KEY_GEMINI",
				"baseURL": "BASE_URL_GEMINI",
				"model": "gemini-3.1-flash-lite-preview"
			}
		},
		{
			"id": "out1",
			"type": "outputLog",
			"input": {
				"source": "$llmChat"
			}
		}
	],
	"form": [
		{
			"id": "userInput.string",
			"name": "Enter inquiry",
			"value": null,
			"type": "textarea",
			"required": true,
			"autoclear": true
		}
	],
	"output": {
		"cards": [
			{
				"id": "llmChat.value",
				"type": "text",
				"name": "Response",
				"format": "markdown"
			},
			{
				"id": "userInput.value",
				"type": "text",
				"name": "User"
			}
		]
	},
	"meta": {
		"name": "Quick Assistant",
		"description": "Google Gemini 3.1 Flash (lite-preview)",
		"disableConfirm": true,
		"notifyOnEnd": true
	}
}