{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "The date is {{:datenow}}. Summarize the news content for me and prioritize only the most important and the most immediate effect for me here in PH. Do not show any low-quality unnecessary news (e.g. celebrity, drama, upcoming media, etc.). Present this in proper Markdown format."
			}
		},
		{
			"id": "news1",
			"type": "fetchRss",
			"input": {
				"url": "https://www.manilatimes.net/news/feed/",
				"fields": {
					"items": [
						"title",
						"description"
					]
				}
			}
		},
		{
			"id": "news2",
			"type": "fetchRss",
			"input": {
				"url": "https://www.philstar.com/rss/headlines",
				"fields": {
					"items": [
						"title",
						"description"
					]
				}
			}
		},
		{
			"id": "userPrompt",
			"type": "joinString",
			"input": {
				"sources": [
					"$news1",
					"$news2"
				],
				"separator": "\n\n\n\n"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$systemPrompt",
				"userPrompt": "$userPrompt",
				"testMode": false,
				"maxTokens": 2048,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "outputLog",
			"input": {
				"source": "$llm1"
			}
		}
	],
	"output": {
		"cards": [
			{
				"id": "llm1.value",
				"type": "text",
				"name": "Latest News",
				"format": "markdown"
			}
		]
	},
	"meta": {
		"name": "PH Latest news",
		"description": "Up-to-date important news via RSS data.",
		"notifyOnEnd": true
	}
}