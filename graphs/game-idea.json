{
	"graph": [
		{
			"id": "scratchFile",
			"type": "readFromTextFile",
			"input": {
				"path": "E:/idea.txt"
			}
		},
		{
			"id": "ideaInstructions",
			"type": "constantString",
			"input": {
				"string": "Summarize and cleanup this input taken from user's game idea stash. Turn it into a practical and doable game idea and evaluate and critic the story and features stated and provide suggestions."
			}
		},
		{
			"id": "idea1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$ideaInstructions",
				"userPrompt": "$scratchFile",
				"testMode": false,
				"maxTokens": 4096,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "idea2",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$ideaInstructions",
				"userPrompt": "$scratchFile",
				"testMode": false,
				"maxTokens": 4096,
				"temperature": 0.7,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "ideaBoth",
			"type": "templateString",
			"input": {
				"template": "===Idea 1:===\n{0}\n\n\n===Idea 2:===\n{1}",
				"sources": [
					"$idea1",
					"$idea2"
				]
			}
		},
		{
			"id": "llmChecker",
			"type": "callLLM",
			"input": {
				"systemPrompt": "Compare and evaluate both game ideas and take the strong points to form a coherent proper game idea that can be done practically by a solo developer.",
				"userPrompt": "$ideaBoth",
				"testMode": false,
				"maxTokens": 4096,
				"temperature": 0.3,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "$llmChecker",
				"path": "E:/projects/flowbench/reports/game-idea-{{:datenow}}.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	]
}