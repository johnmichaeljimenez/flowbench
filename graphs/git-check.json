{
	"graph": [
		{
			"id": "userQuestion",
			"type": "constantString",
			"input": {
				"string": "Please check my staged files for first-level quick sanity checking for typos, high-level possible errors, forgotten or misplaced code, etc. Thank you."
			}
		},
		{
			"id": "blob",
			"type": "gitListStagedFiles",
			"input": {
				"repoPath": "E:/projects/flowbench"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$userQuestion",
				"userPrompt": "$blob",
				"testMode": false,
				"maxTokens": 4096,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "$llm1",
				"path": "E:/projects/flowbench/reports/git-stage.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	]
}