{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "Summarize the news content for me and prioritize only the most important and the most immediate effect for me here in PH. Do not show any low-quality unnecessary news (e.g. celebrity, drama, upcoming media, etc.). Then do a general summary of the news on the last part. And attach a bible verse on the last part that is fit for the overall context and summary of the news."
			}
		},
		{
			"id": "news1",
			"type": "fetchRss",
			"input": {
				"url": "https://www.manilatimes.net/news/feed/",
				"fields": { "items": ["title", "description"] }
			}
		},
		{
			"id": "news2",
			"type": "fetchRss",
			"input": {
				"url": "https://www.philstar.com/rss/headlines",
				"fields": { "items": ["title", "description"] }
			}
		},
		{
			"id": "userPrompt",
			"type": "joinString",
			"input": {
				"sources": [ "$news1", "$news2" ],
				"separator": "\n\n\n\n"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$systemPrompt",
				"userPrompt": "$userPrompt",
				"testMode": false,
				"maxTokens": 2048,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "$llm1",
				"path": "E:/projects/flowbench/reports/news_{{:datenow}}.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	]
}