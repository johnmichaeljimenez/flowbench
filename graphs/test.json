{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "You are a helpful assistant"
			}
		},
		{
			"id": "userPrompt",
			"type": "loadTextBlob",
			"input": {
				"path": "E:/projects/flowbench",
				"whitelist": "Makefile;.c;.js;.cs;.html;.txt",
				"blacklist": ".gitignore;node_modules;.env"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "systemPrompt",
				"userPrompt": "userPrompt",
				"testMode": true,
				"maxTokens": 2048,
				"temperature": 0.5,
				"apiKeyName": "api1",
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "outputLog",
			"input": {
				"source": "userPrompt"
			}
		}
	]
}