{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "You are a useful assistant."
			}
		},
		{
			"id": "userPrompt",
			"type": "fetchApi",
			"input": {
				"url": "https://bored-api.appbrewery.com/random",
				"schema": {
					"type": "activity"
				}
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "systemPrompt",
				"userPrompt": "userPrompt",
				"testMode": true,
				"maxTokens": 2048,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "userPrompt",
				"path": "E:/projects/flowbench/reports/test.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	]
}