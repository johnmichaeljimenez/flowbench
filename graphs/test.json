{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "You are a helpful assistant"
			}
		},
		{
			"id": "testUserPrompt",
			"type": "constantString",
			"input": {
				"string": "What is your model and when is your knowledge cutoff?"
			}
		},
		{
			"id": "userPrompt",
			"type": "loadTextBlob",
			"input": {
				"path": "E:/projects/flowbench",
				"whitelist": "Makefile;.c;.js;.cs;.html;.txt",
				"blacklist": ".gitignore;node_modules;.env"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "systemPrompt",
				"userPrompt": "testUserPrompt",
				"testMode": true,
				"maxTokens": 1024,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-non-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "llm1",
				"path": "E:/projects/flowbench/graphs/output.md",
				"append": true,
				"encoding": "utf-8"
			}
		}
	]
}