{
  "graph": [
    {
      "id": "projectOutputName",
      "type": "constantString",
      "input": {
        "string": "project-report-{{:datenow}}.md"
      }
    },
    {
      "id": "projectDescPath",
      "type": "constantString",
      "input": {
        "string": ""
      }
    },
    {
      "id": "projectDesc",
      "type": "joinString",
      "input": {
        "sources": [
          "$projectDescPath",
          "project-description.txt"
        ],
        "fileSeparator": true
      }
    },
		{
			"id": "projectDescString",
			"type": "readFromTextFile",
			"input": {
				"path": "$projectDesc"
			}
		},
    {
      "id": "projectTodo",
      "type": "joinString",
      "input": {
        "sources": [
          "$projectDescPath",
          "TODO.txt"
        ],
        "fileSeparator": true
      }
    },
		{
			"id": "projectTodoString",
			"type": "readFromTextFile",
			"input": {
				"path": "$projectTodo"
			}
		},
    {
      "id": "projectDescOutput",
      "type": "joinString",
      "input": {
        "sources": [
          "$projectDescPath",
          "reports",
          "$projectOutputName"
        ],
        "fileSeparator": true
      }
    },
    {
      "id": "projectPath",
      "type": "constantString",
      "input": {
        "string": ""
      }
    },
    {
      "id": "projectBlobString",
      "type": "loadTextBlob",
      "input": {
        "path": "$projectPath",
        "whitelist": ".js;.json;.html;.css;.txt",
        "blacklist": "package-lock.json;reports;graphs;.temp"
      }
    },
    {
      "id": "combinedPrompt",
      "type": "templateString",
      "input": {
        "template": "PROJECT SCOPE & VISION:\n\n{0}\n==========\n\nTODO LIST (with target dates and status):\n\n{1}\n==========\n\nFULL PROJECT CODEBASE & FILES:\n\n{2}",
        "sources": [
          "$projectDescString",
          "$projectTodoString",
          "$projectBlobString"
        ]
      }
    },
    {
      "id": "projectManager",
      "type": "callLLM",
      "input": {
        "systemPrompt": "You are an extremely honest, strategic, and experienced project manager for a personal solo coding project. Today is {{:datenow}}. Analyze the full context and write a professional detailed status report with these exact sections only:\n\n1. Overall Status (On Track / Slipping / Ahead of schedule / what are the TODO tasks that are already done and existing on the code)\n2. Key Strengths + Comparison to other relevant Github repo projects\n3. Weaknesses & Risks (relevant to the scope)\n4. Priority Tasks for the next 7 days (with realistic deadlines and why they matter)\n5. Personal Performance Score (1-10) + detailed honest explanation.\nUse bullet points.",
        "userPrompt": "$combinedPrompt",
        "maxTokens": 4096,
        "testMode": false,
        "temperature": 0.5,
        "apiKey": "API_KEY_GROK",
        "baseURL": "BASE_URL_GROK",
        "model": "grok-4-1-fast-reasoning",
        "useTools": true
      }
    },
    {
      "id": "saveReport",
      "type": "writeToTextFile",
      "input": {
        "source": "$projectManager",
        "path": "$projectDescOutput",
        "append": false,
        "forceWrite": true
      }
    },
    {
      "id": "out1",
      "type": "outputLog",
      "input": {
        "source": "✅ Project Manager Report generated!\nSaved as: project-report-{{:datenow}}.md"
      }
    }
  ],
  "form": [
    {
      "id": "projectPath.string",
      "name": "Project root folder",
      "value": "E:/projects/flowbench",
      "type": "textfield",
      "required": true
    },
    {
      "id": "projectDescPath.string",
      "name": "Project description & specs folder",
      "value": "E:/flowbench/project-desc",
      "type": "textfield",
      "required": true
    }
  ],
  "entryPoints": [
    "saveReport",
    "out1"
  ],
  "output": {
    "cards": [
      {
        "id": "saveReport.value",
        "type": "text",
        "name": "Project Status Report"
      }
    ]
  }
}