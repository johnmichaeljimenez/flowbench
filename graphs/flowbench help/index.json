{
	"graph": [
		{
			"id": "userQuestion",
			"type": "constantString",
			"input": {
				"string": ""
			}
		},
		{
			"id": "blob",
			"type": "loadTextBlob",
			"input": {
				"path": "E:/projects/flowbench",
				"whitelist": ".js;.json;.txt",
				"blacklist": ".gitignore;node_modules;.env;package-lock.json;reports;examples"
			}
		},
		{
			"id": "blobQuery",
			"type": "templateString",
			"input":{
				"template":"{0}\n\n\n{1}",
				"sources": [
					"$userQuestion",
					"$blob"
				]
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "$userQuestion",
				"userPrompt": "$blob",
				"testMode": false,
				"maxTokens": 4096,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning"
			}
		},
		{
			"id": "query",
			"type": "choose",
			"input": {
				"condition": true,
				"trueSource": "$blobQuery",
				"falseSource": "$llm1"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "$query",
				"path": "./.temp/reports/flowbench-help-{{:datenow}}.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	],
	"form": [
		{
			"id": "userQuestion.string",
			"name": "Enter inquiry",
			"value": null,
			"type": "textarea",
			"storeLast": true,
			"required": true
		},
		{
			"type": "dropdown",
			"id": "query.condition",
			"name": "Text Blob only",
			"storeLast": true,
			"data": [
				{
					"value": "true",
					"display": "Yes"
				},
				{
					"value": "false",
					"display": "No"
				}
			],
			"defaultValue": "true",
			"required": true
		}
	],
	"output": {
		"cards": [
			{
				"id": "out1.value",
				"type": "text",
				"name": "Response",
				"format": "markdown"
			}
		]
	},
	"meta": {
		"name": "Flowbench Help",
		"description": "Coding assistant graph for self-improving code and architecture",
		"notifyOnEnd": true
	}
}