{
	"graph": [
		{
			"id": "systemPrompt",
			"type": "constantString",
			"input": {
				"string": "Is the save version handling and migration correct here? version 2 and 3 are just placeholders for now, and our game is yet to be released. so this save versioning is just preparation and I want to know if these are all correct at least."
			}
		},
		{
			"id": "saveHandler",
			"type": "readFromTextFile",
			"input": {
				"path": "E:/Projects/Game/Scripts/Core/Save/SaveHandler.cs"
			}
		},
		{
			"id": "playerSaveFile",
			"type": "readFromTextFile",
			"input": {
				"path": "E:/Projects/Game/Scripts/Core/Save/PlayerSaveFile.cs"
			}
		},
		{
			"id": "userPrompt",
			"type": "templateString",
			"input": {
				"sources": [
					"saveHandler",
					"playerSaveFile"
				],

				"template": "[SaveHandler.cs]\n\n{0}\n\n\n\n[PlayerSaveFile.cs]\n\n{1}"
			}
		},
		{
			"id": "llm1",
			"type": "callLLM",
			"input": {
				"systemPrompt": "systemPrompt",
				"userPrompt": "userPrompt",
				"testMode": false,
				"maxTokens": 2048,
				"temperature": 0.5,
				"apiKey": "API_KEY_GROK",
				"baseURL": "BASE_URL_GROK",
				"model": "grok-4-1-fast-reasoning"
			}
		},
		{
			"id": "out1",
			"type": "writeToTextFile",
			"input": {
				"source": "llm1",
				"path": "E:/projects/flowbench/reports/save-versioning.md",
				"append": false,
				"encoding": "utf-8"
			}
		}
	]
}