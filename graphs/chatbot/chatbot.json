{
  "graph": [
    {
      "id": "pathHistory",
      "type": "constantString",
      "input": {
        "string": "./graphs/chatbot/.temp/history.txt"
      }
    },
    {
      "id": "pathMemory",
      "type": "constantString",
      "input": {
        "string": "./graphs/chatbot/.temp/memory.txt"
      }
    },
    {
      "id": "historyFile",
      "type": "readFromTextFile",
      "input": {
        "path": "$pathHistory"
      }
    },
    {
      "id": "memoryFile",
      "type": "readFromTextFile",
      "input": {
        "path": "$pathMemory"
      }
    },
    {
      "id": "sysPrompt",
      "type": "constantString",
      "input": {
        "string": "You are a friendly, concise chatbot. Answer conversationally. Use memory where appropriate. The date-time is {{:datenow}}"
      }
    },
    {
      "id": "sysPrompt2",
      "type": "constantString",
      "input": {
        "string": "You are a memory manager LLM. Only output KEY=VALUE lines only for the most important facts about the user. Do not include any explanations or text outside KEY=VALUE format. Return the exact same input if nothing useful needs to be written. If memory input is empty, put <No memory found> instead as output."
      }
    },
    {
      "id": "userInput",
      "type": "constantString",
      "input": {
        "string": "Hello, who are you?"
      }
    },
    {
      "id": "chatPrompt",
      "type": "templateString",
      "input": {
        "template": "Memory:\n{0}\n\nConversation so far:\n{1}\nUser: {2}\nAssistant:",
        "sources": [
          "$memoryFile",
          "$historyFile",
          "$userInput"
        ]
      }
    },
    {
      "id": "llmChat",
      "type": "callLLM",
      "input": {
        "systemPrompt": "$sysPrompt",
        "userPrompt": "$chatPrompt",
        "maxTokens": 512,
        "temperature": 0.7,
        "apiKey": "API_KEY_GROK",
        "baseURL": "BASE_URL_GROK",
        "model": "grok-4-1-fast-reasoning",
        "useTools": true
      }
    },
    {
      "id": "memoryUpdatePrompt",
      "type": "templateString",
      "input": {
        "template": "Memory before update:\n{0}\n\nLatest conversation:\nUser: {1}\nAssistant: {2}\n\nUpdate the memory with any new or changed facts. Return only KEY=VALUE lines, overwrite keys if needed.",
        "sources": [
          "$memoryFile",
          "$userInput",
          "$llmChat"
        ]
      }
    },
    {
      "id": "llmMemoryUpdater",
      "type": "callLLM",
      "input": {
        "systemPrompt": "$sysPrompt2",
        "userPrompt": "$memoryUpdatePrompt",
        "maxTokens": 256,
        "temperature": 0.5,
        "apiKey": "API_KEY_GROK",
        "baseURL": "BASE_URL_GROK",
        "model": "grok-4-1-fast-non-reasoning"
      }
    },
    {
      "id": "saveMemory",
      "type": "writeToTextFile",
      "input": {
        "source": "$llmMemoryUpdater",
        "path": "$pathMemory",
        "append": false,
        "encoding": "utf-8",
        "forceWrite": true
      }
    },
    {
      "id": "historyAppend",
      "type": "templateString",
      "input": {
        "template": "{0}\n==========\nUser: {1}\nAssistant: {2}\n\n",
        "sources": [
          "$historyFile",
          "$userInput",
          "$llmChat"
        ]
      }
    },
    {
      "id": "saveHistory",
      "type": "writeToTextFile",
      "input": {
        "source": "$historyAppend",
        "path": "$pathHistory",
        "append": false,
        "encoding": "utf-8",
        "forceWrite": true
      }
    },
    {
      "id": "out1",
      "type": "templateString",
      "input": {
        "template": "Chat run complete.\n\nMemory updated:\n{0}\n\nHistory updated:\n{1}",
        "sources": [
          "$saveMemory",
          "$saveHistory"
        ]
      }
    }
  ],
  "form": [
    {
      "id": "userInput.string",
      "name": "Enter inquiry",
      "value": null,
      "type": "textfield",
      "required": true,
      "autoclear": true
    }
  ],
  "output": {
    "cards": [
      {
        "id": "llmChat.value",
        "type": "text",
        "name": "Chat"
      }
    ]
  }
}